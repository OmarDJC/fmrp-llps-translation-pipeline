#Purpose:Compare CDS length across translational efficiency (TE) groups,
#Apply Holm correction to control family-wise error rate

#Plot A: CDS length distribution
p1 <- ggbetweenstats(
  data = data1,
  x = group,
  y = CDS,
  results.subtitle = FALSE,
  var.equal = TRUE,
  p.adjust.method = "holm",
  pairwise.display = "none",

  point.args = list(
    position = position_jitterdodge(dodge.width = 0.6),
    alpha = 0
  ),

  violin.args = list(width = 0.5, alpha = 0.1, fill = "white"),
  boxplot.args = list(width = 0.3, alpha = 0.4, fill = group_colors),

  ggsignif.args = list(textsize = 3.5),
  centrality.label.args = list(size = 4)
) +
  ylab("CDS length (kb, Log scale)") +
  scale_y_continuous(
    trans = pseudo_log_trans(sigma = 1, base = exp(1)),
    limits = c(0, exp(3.5)),
    breaks = c(0,1,2,3,5,10,15,20),
    labels = comma
  ) +
  theme_ipsum(base_size = 16) +
  theme(legend.position = "none") +
  stat_pvalue_manual(stat.test1, label = "p = {p.adj}")

